---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';

// Load markdown project files from `src/content/projects`.
const modules = import.meta.glob('../content/projects/*.md', { eager: true });
const projects = Object.values(modules).map(m => ({ ...m.frontmatter }));
---

<BaseLayout title="Portfolio">
  <section class="hero hero-home">
    <div class="hero-overlay"></div>
    <div class="hero-inner">
      <div class="hero-copy">
        <span class="eyebrow">DESIGNER • ILLUSTRATOR • DEVELOPER</span>
        <h1 class="hero-title">Isabella Valdez</h1>
        <p class="hero-subtitle">I’m a visual communication designer who enjoys blending UX, illustration, and code to create meaningful digital experiences. Through thoughtful design and strong storytelling, I aim to make every project both useful and memorable.</p>
      </div>
      <div class="hero-logo-wrap">
        <img class="hero-logo" src="/images/logos/Logo-white.png" alt="Portfolio logo" />
      </div>
    </div>
  </section>

  <section class="about" id="about">
    <div class="about-inner">
      <div class="about-copy">
        <div class="section-head">
          <div>
            <span class="eyebrow">About</span>
            <h2>Creating Experiences Through Design, Illustration, and Code</h2>
          </div>
        </div>

        <p class="lead">
          I'm Isabella Valdez, a Visual Communication Design student at Eastern Washington University with a passion for storytelling through digital experiences. My work combines UX design, illustration, branding, and front-end development to create projects that are both functional and visually engaging. Whether I'm designing interfaces, building websites, or creating graphics, I enjoy finding creative solutions that connect with people and communicate ideas clearly.
        </p>
      </div>

      <div class="about-visual">
        <img
          class="about-photo"
          src="/images/headshots/pic3.jpeg"
          alt="Portrait of Isabella Valdez"
        />

        <div class="about-thumbs">
          <img src="/images/drawings/drawing3.jpg" />
          <img src="/images/drawings/drawing4.jpg" />
          <img src="/images/drawings/drawing6.jpg" />
          <img src="/images/drawings/drawing7.jpg" />
          <img src="/images/drawings/drawing8.jpg" />
          <img src="/images/drawings/drawing12.png" />
          <img src="/images/drawings/drawing13.png" />
          <img src="/images/drawings/drawing14.png" />
        </div>
      </div>
    </div>
  </section>

  <section class="projects" id="projects">
    <div class="section-head">
      <div>
        <span class="eyebrow">Projects</span>
        <h2>Selected Work</h2>
      </div>
    </div>
    <div class="grid">
      {projects.map(project => (
        <ProjectCard project={project} />
      ))}
    </div>
  </section>

  <section class="contact" id="contact">
    <div class="section-head">
      <div>
        <span class="eyebrow">Contact</span>
        <h2>Let's Connect</h2>
      </div>
    </div>

    <p class="lead">
      Interested in a project, collaboration, or just want to say hello? I'd love to hear from you. Feel free to reach out through any of the channels below.
    </p>

    <div class="footer">
      <p>
        <strong>Email:</strong>
        <a href="mailto:izzyval2005@gmail.com">izzyval2005@gmail.com</a>
      </p>

      <p>
        <strong>Instagram:</strong>
        <a href="https://www.instagram.com/i22y_v/" target="_blank" rel="noopener noreferrer">
          @i22y_v
        </a>
      </p>

      <p>
        <strong>GitHub:</strong>
        <a href="https://github.com/ValdezIzzy" target="_blank" rel="noopener noreferrer">
          ValdezIzzy
        </a>
      </p>

      <p>
        <strong>LinkedIn:</strong>
        <a href="https://www.linkedin.com/in/isabella-valdez-17816336b/" target="_blank" rel="noopener noreferrer">
          Isabella Valdez
        </a>
      </p>
    </div>
  </section>
</BaseLayout>
